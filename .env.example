# ALSO / Sotopia experiment environment template.
# Copy this file to `.env` and replace placeholder values before running experiments:
#   cp .env.example .env

# Model provider credentials. The provided configs use OpenRouter-style model names.
CUSTOM_API_KEY=replace_with_your_openrouter_key
# Optional Redis connection override.
# Leave unset when using the local `redis-stack` Docker container on localhost:6379.
# For a remote or password-protected Redis, use a URL such as:
# REDIS_OM_URL=redis://default:password@host:6379

# Optional LiteLLM/OpenRouter routing metadata.
# OPENROUTER_SITE_URL=https://babylonehy.github.io/ALSO/
# OPENROUTER_APP_NAME=ALSO

# Optional proxy settings. Set only if your environment needs them.
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1
